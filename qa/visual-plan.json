{
  "scenarios": [
    {
      "id": "generator-mode-chooser",
      "name": "Volba pracovního režimu",
      "url": "/dist/index.html",
      "expectedText": "PRACOVNÍ REŽIM",
      "mustVisible": [
        "#appModePanel"
      ],
      "steps": [
        {
          "action": "wait",
          "ms": 1200
        },
        {
          "action": "evaluate",
          "script": "document.querySelectorAll('.welcome-gate').forEach(x=>x.remove());document.body.classList.remove('onboarding-locked');window.scrollTo(0,0);"
        }
      ],
      "viewports": [
        {
          "width": 360,
          "height": 800
        },
        {
          "width": 1366,
          "height": 768
        }
      ]
