{
  "standard": "GHRAB-QA-1.0.2",
  "appId": "generator-testu",
  "appName": "Generátor interaktivních testů",
  "appVersion": "7.1.4",
  "entryPoint": "dist/index.html",
  "serveRoot": ".",
  "buildRoot": "dist",
  "installCommand": "npm ci --no-fund",
  "buildCommand": "npm run build",
  "testCommand": "npm test",
  "headlessCommand": "npm run test:headless && node scripts/qa-generate-fixtures.mjs",
  "auditCommand": "npm --fetch-timeout=30000 --fetch-retries=1 audit --audit-level=high",
  "features": {
    "pwa": true,
    "ai": true,
    "centralAccessGuard": true,
    "fileExport": true,
    "studentRuntime": true,
    "teacherRuntime": true,
    "localStorage": true,
    "serviceWorker": true
  },
  "requiredViewports": [
    {
      "width": 360,
      "height": 800
    },
    {
      "width": 412,
      "height": 915
    },
    {
      "width": 768,
      "height": 1024
    },
    {
      "width": 1366,
      "height": 768
    },
    {
      "width": 1920,
      "height": 1080
    }
  ],
  "versionChecks": [
    {
      "file": "src/js/01-core.js",
      "regex": "version:\\s*['\\\"]([0-9.]+)['\\\"]",
      "expected": "7.1.4"
    },
    {
      "file": "public/sw.js",
      "regex": "generator-testu-pwa-v([0-9.]+)",
      "expected": "7.1.4"
    },
    {
      "file": "public/manifest.webmanifest",
      "regex": "[?&]v=([0-9.]+)",
      "expected": "7.1.4"
    },
    {
      "file": "dist/studio-manifest.json",
      "regex": "\"version\"\\s*:\\s*\"([0-9.]+)\"",
      "expected": "7.1.4"
    }
  ],
  "pwaTargets": [
    {
      "id": "generator-testu",
      "root": "dist",
      "manifest": "manifest.webmanifest",
      "serviceWorker": "sw.js",
      "cachePrefix": "generator-testu-pwa-v"
    }
  ],
  "security": {
    "allowedEmails": [
      "balaz@ghrabuvka.cz"
    ],
    "requiresCsvFormulaProtection": true
  },
  "compatibility": {
    "runtimeSourceRoots": [
      "src",
      "public"
    ],
    "disallowRegexLookbehind": true
  }
}
